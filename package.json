    "build": "tsc -b && vite build",
    "preview": "vite preview"
  },
  "dependencies": {
    "datocms-plugin-sdk": "^2.1.1",
    "datocms-react-ui": "^2.1.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-phone-number-input": "^3.4.16"
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^6.0.1",
    "globals": "^17.4.0",
    "typescript": "^6.0.2",
    "vite": "^8.0.3"
  }
}
